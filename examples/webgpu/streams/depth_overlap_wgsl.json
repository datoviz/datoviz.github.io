{
  "name": "depth_overlap_wgsl",
  "description": "DRP2 WebGPU stream with two overlapping triangles and depth testing. The smaller green triangle is nearer and should appear on top of the larger red triangle.",
  "version": { "major": 2, "minor": 0 },
  "commands": [
    {
      "cmd": "HelloRenderer",
      "version": { "major": 2, "minor": 0 },
      "client_name": "drp2-webgpu-poc"
    },
    {
      "cmd": "RendererHelloReply",
      "version": { "major": 2, "minor": 0 },
      "status": "ok",
      "renderer_name": "webgpu-poc"
    },
    {
      "cmd": "CreateBuffer",
      "id": 1,
      "label": "overlap_vertices",
      "size": 144,
      "usage": ["VERTEX", "COPY_DST"]
    },
    {
      "cmd": "WriteBuffer",
      "buffer_id": 1,
      "offset": 0,
      "size": 144,
      "data": "AABAv2Zm5r4AAEA/AACAP83MzD2amRk+AABAP2Zm5r4AAEA/AACAP83MzD2amRk+AAAAABSuRz8AAEA/AACAP83MzD2amRk+Urgevylcj74AAIA+zczMPTMzcz8zM7M+UrgePylcj74AAIA+zczMPTMzcz8zM7M+AAAAAHE9Cj8AAIA+zczMPTMzcz8zM7M+"
    },
    {
      "cmd": "CreateTexture",
      "id": 2,
      "label": "canvas_depth",
      "dimension": "2d",
      "width": "canvas",
      "height": "canvas",
      "depth": 1,
      "format": "depth32float",
      "usage": ["RENDER_ATTACHMENT"],
      "mip_level_count": 1,
      "sample_count": 1
    },
    {
      "cmd": "CreateShaderModule",
      "id": 10,
      "stage": "VERTEX",
      "format": "wgsl",
      "entry_point": "vs_main",
      "code": "struct VsIn {\n    @location(0) pos: vec3f,\n    @location(1) color: vec3f,\n};\n\nstruct VsOut {\n    @builtin(position) pos: vec4f,\n    @location(0) color: vec3f,\n};\n\n@vertex\nfn vs_main(in: VsIn) -> VsOut {\n    var out: VsOut;\n    out.pos = vec4f(in.pos, 1.0);\n    out.color = in.color;\n    return out;\n}"
    },
    {
      "cmd": "CreateShaderModule",
      "id": 11,
      "stage": "FRAGMENT",
      "format": "wgsl",
      "entry_point": "fs_main",
      "code": "struct FsIn {\n    @location(0) color: vec3f,\n};\n\n@fragment\nfn fs_main(in: FsIn) -> @location(0) vec4f {\n    return vec4f(in.color, 1.0);\n}"
    },
    {
      "cmd": "CreateRenderPipeline",
      "id": 20,
      "vertex_shader_module_id": 10,
      "fragment_shader_module_id": 11,
      "vertex_buffer_slots": 1,
      "vertex_buffers": [
        {
          "array_stride": 24,
          "step_mode": "vertex",
          "attributes": [
            { "format": "float32x3", "offset": 0, "shader_location": 0 },
            { "format": "float32x3", "offset": 12, "shader_location": 1 }
          ]
        }
      ],
      "topology": "triangle-list",
      "depth_stencil": {
        "format": "depth32float",
        "depth_write_enabled": true,
        "depth_compare": "less"
      },
      "color_targets": [
        { "format": "canvas" }
      ]
    },
    {
      "cmd": "BeginCommandEncoder",
      "id": 30
    },
    {
      "cmd": "BeginRenderPass",
      "id": 31,
      "encoder_id": 30,
      "color_attachments": [
        {
          "texture_id": 0,
          "load_op": "clear",
          "store_op": "store",
          "clear_value": { "r": 0.02, "g": 0.03, "b": 0.05, "a": 1.0 }
        }
      ],
      "depth_stencil_attachment": {
        "texture_id": 2,
        "depth_load_op": "clear",
        "depth_store_op": "store",
        "depth_clear_value": 1.0
      }
    },
    {
      "cmd": "SetPipeline",
      "pass_id": 31,
      "pipeline_id": 20
    },
    {
      "cmd": "SetVertexBuffer",
      "pass_id": 31,
      "slot": 0,
      "buffer_id": 1,
      "offset": 0
    },
    {
      "cmd": "Draw",
      "pass_id": 31,
      "vertex_count": 6,
      "instance_count": 1,
      "first_vertex": 0,
      "first_instance": 0
    },
    {
      "cmd": "EndRenderPass",
      "pass_id": 31
    },
    {
      "cmd": "FinishCommandEncoder",
      "encoder_id": 30,
      "command_buffer_id": 32
    },
    {
      "cmd": "QueueSubmit",
      "command_buffer_ids": [32]
    }
  ],
  "expected": {
    "outcome": "green_triangle_in_front_of_red_triangle"
  }
}
